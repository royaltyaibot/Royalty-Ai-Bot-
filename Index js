const WebSocket = require('ws');
const express = require('express');
const app = express();

const token = process.env.TOKEN; // API token from Deriv

let botRunning = false;
let digits = [];
let profit = 0;
let lossCount = 0;
let stake = 0.20;
let lastPrediction = "-";
let totalTrades = 0;
let wins = 0;
let lastResult = "";

const ws = new WebSocket(`wss://ws.derivws.com/websockets/v3?app_id=1089`);

ws.onopen = () => {
    ws.send(JSON.stringify({ authorize: token }));
};

ws.onmessage = (msg) => {
    const data = JSON.parse(msg.data);

    if (data.msg_type === 'authorize') {
        ws.send(JSON.stringify({ ticks: "R_75", subscribe: 1 }));
    }

    if (data.msg_type === 'tick') {
        let lastDigit = parseInt(data.tick.quote.toString().slice(-1));
        digits.push(lastDigit);
        if (digits.length > 10) digits.shift();

        if (digits.length === 10) {
            let freq = {};
            digits.forEach(d => freq[d] = (freq[d] || 0) + 1);
            let mostCommon = Object.keys(freq)
                .reduce((a, b) => freq[a] > freq[b] ? a : b);

            lastPrediction = mostCommon;
            let strongSignal = freq[mostCommon] >= 4;
            let lastTwoDifferent = digits[8] !== digits[9];

            if (botRunning && strongSignal && lastTwoDifferent && lossCount < 3) {
                ws.send(JSON.stringify({
                    buy: 1,
                    price: stake,
                    parameters: {
                        amount: stake,
                        basis: "stake",
                        contract_type: "DIGITDIFF",
                        currency: "USD",
                        duration: 1,
                        duration_unit: "t",
                        symbol: "R_75",
                        barrier: mostCommon
                    }
                }));
                totalTrades++;
            }
        }
    }

    if (data.msg_type === 'proposal_open_contract') {
        if (data.proposal_open_contract.status === "won") {
            profit += stake * 0.9;
            wins++;
            lossCount = 0;
            stake = 0.20;
            lastResult = "win";
        } else if (data.proposal_open_contract.status === "lost") {
            profit -= stake;
            lossCount++;
            stake *= 1.3;
            lastResult = "loss";
        }
    }
};

// Safety stop
setInterval(() => {
    if (profit >= 2 || profit <= -1) botRunning = false;
}, 2000);

// Dashboard routes
app.get('/data', (req, res) => {
    res.json({ profit, lastPrediction, totalTrades, wins, lossCount, lastResult });
});
app.get('/start', (req, res) => { botRunning = true; res.send("Started"); });
app.get('/stop', (req, res) => { botRunning = false; res.send("Stopped"); });
app.use(express.static('.'));
app.listen(3000, () => console.log("Running"));
